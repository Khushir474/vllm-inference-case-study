# Hosted inference API (Together AI)
HOSTED_API_KEY=

# Self-hosted vLLM server (OpenAI-compatible). Point this at your cloud GPU box once it's up.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=not-needed
# On-demand $/hr for whatever GPU instance is serving vLLM (e.g. RunPod A10G/L4 rate).
VLLM_GPU_HOURLY_COST_USD=0.0

# LLM judge (Anthropic)
ANTHROPIC_API_KEY=
